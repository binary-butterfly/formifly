{
  "name": "formifly",
  "version": "3.0.0-rc1",
  "description": "React form handling as light as a butterfly",
  "exports": {
    ".": {
      "types": "./dist/src/js/main.d.ts",
      "import": "./dist/formifly.js",
      "require": "./dist/formifly.umd.cjs"
    }
  },
  "main": "dist/formifly.umd.cjs",
  "module": "dist/formifly.js",
  "types": "dist/src/js/main.d.ts",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "coverage": "vitest --run --coverage",
    "build:dev": "vite build",
    "build:prod": "NODE_ENV=production vite build",
    "start": "vite",
    "prepublishOnly": "npm run build:prod"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/binary-butterfly/formifly.git"
  },
  "keywords": [
    "react",
    "forms"
  ],
  "author": "binary butterfly GmbH",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/binary-butterfly/formifly/issues"
  },
  "homepage": "https://github.com/binary-butterfly/formifly#readme",
  "devDependencies": {
    "@binary-butterfly/eslint-config": "^1.0.0-rc5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "i18next": "^26.0.6",
    "jest-styled-components": "^7.4.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-i18next": "^17.0.4",
    "styled-components": "^5.3.3 || ^6.1.0 || ^6.4.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
